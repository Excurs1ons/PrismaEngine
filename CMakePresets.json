{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 31,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-base",
      "hidden": true,
      "description": "Base Windows configuration (使用 FetchContent 管理依赖)",
      "generator": "Visual Studio 17 2022",
      "environment": {},
      "cacheVariables": {
        "PRISMA_USE_FETCHCONTENT": "ON",
        "PRISMA_BUILD_EDITOR": "OFF",
        "PRISMA_ENABLE_RENDER_DX12": "ON",
        "PRISMA_ENABLE_AUDIO_XAUDIO2": "ON",
        "PRISMA_ENABLE_RENDER_VULKAN": "OFF",
        "PRISMA_ENABLE_UPSCALER_FSR": "OFF",
        "PRISMA_ENABLE_UPSCALER_DLSS": "OFF",
        "PRISMA_ENABLE_UPSCALER_TSR": "OFF"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-engine-base",
      "hidden": true,
      "inherits": "windows-base",
      "description": "Base Windows Engine configuration",
      "cacheVariables": {
        "PRISMA_BUILD_EDITOR": "OFF"
      }
    },
    {
      "name": "windows-editor-base",
      "hidden": true,
      "inherits": "windows-base",
      "description": "Base Windows Editor configuration",
      "cacheVariables": {
        "PRISMA_BUILD_EDITOR": "ON",
        "PRISMA_ENABLE_IMGUI_DEBUG": "ON"
      }
    },
    {
      "name": "android-base",
      "hidden": true,
      "description": "Base Android configuration (使用 FetchContent 管理依赖)",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "Android",
        "PRISMA_USE_FETCHCONTENT": "ON",
        "PRISMA_BUILD_EDITOR": "OFF",
        "PRISMA_ENABLE_RENDER_DX12": "OFF",
        "PRISMA_ENABLE_AUDIO_XAUDIO2": "OFF",
        "PRISMA_ENABLE_RENDER_VULKAN": "ON",
        "CMAKE_FIND_PACKAGE_PREFER_CONFIG": "OFF",
        "CMAKE_TOOLCHAIN_FILE": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake",
        "ANDROID_NDK": "$env{ANDROID_NDK_HOME}/",
        "ANDROID_PLATFORM": "android-24",
        "CMAKE_ANDROID_STL_TYPE": "c++_shared"
      }
    },
    {
      "name": "linux-base",
      "hidden": true,
      "description": "Base Linux configuration (使用 FetchContent 管理依赖)",
      "generator": "Ninja",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "PRISMA_USE_FETCHCONTENT": "ON",
        "PRISMA_BUILD_EDITOR": "OFF",
        "PRISMA_ENABLE_RENDER_VULKAN": "ON",
        "PRISMA_ENABLE_RENDER_OPENGL": "OFF",
        "PRISMA_ENABLE_AUDIO_SDL3": "ON",
        "PRISMA_ENABLE_INPUT_SDL3": "ON",
        "PRISMA_USE_NATIVE_AUDIO": "OFF",
        "PRISMA_USE_NATIVE_INPUT": "OFF",
        "PRISMA_ENABLE_UPSCALER_FSR": "OFF",
        "PRISMA_ENABLE_UPSCALER_DLSS": "OFF",
        "PRISMA_ENABLE_UPSCALER_TSR": "OFF"
      }
